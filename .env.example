# Public — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3200

# Server only — never import from client code
SUPABASE_SERVICE_ROLE_KEY=

# AI leadership coaching — server-only. The API key must never be
# imported from client code. ANTHROPIC_COACH_MODEL falls back to
# claude-sonnet-4-6 if unset, but set it explicitly to pin the model
# (e.g. claude-opus-4-7, or whatever version you standardize on).
ANTHROPIC_API_KEY=
ANTHROPIC_COACH_MODEL=

# Seed script (server only, see scripts/seed-admin.ts).
# Provide any number of admins. Two patterns are supported:
#   Single:   SEED_ADMIN_EMAIL / SEED_ADMIN_PASSWORD / SEED_ADMIN_NAME
#   Numbered: SEED_ADMIN_1_EMAIL / SEED_ADMIN_1_PASSWORD / SEED_ADMIN_1_NAME
#             SEED_ADMIN_2_EMAIL / SEED_ADMIN_2_PASSWORD / SEED_ADMIN_2_NAME
#             … up to SEED_ADMIN_9_*
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_ADMIN_2_EMAIL=
SEED_ADMIN_2_PASSWORD=
SEED_ADMIN_2_NAME=
